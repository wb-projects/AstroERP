select * from
(SELECT partner.id, partner.kod AS kod
,partner.nev AS nev
,CONCAT(Coalesce(partner.irsz,''),' ',Coalesce(partner.helyseg,''),' ',Coalesce(partner.utca,''),' ',Coalesce(partner.hsz,''),' ',Coalesce(partner.lepcsohaz,''),' ',Coalesce(partner.emelet,''),' ',Coalesce(partner.ajto,'')) AS cim
,CONCAT(Coalesce(partner.p_irsz,''),' ',Coalesce(partner.p_helyseg,''),' ',Coalesce(partner.p_utca,''),' ',Coalesce(partner.p_hsz,''),' ',Coalesce(partner.p_lepcsohaz,''),' ',Coalesce(partner.p_emelet,''),' ',Coalesce(partner.p_ajto,'')) AS p_cim
,partner.telfax AS telfax
,partner.adoszam AS adoszam
,partner.tipus AS tipus
,partner.ugyfeltipus AS ugyfeltipus
,partner.kontakt AS kontaktszemely
,partner.email AS email
,coalesce((Select sum(ossz_brutto) From biz_header, biz_header_ext Where biz_header.kelte BETWEEN {1} AND {2} And biz_header_ext.biz_header_id=biz_header.id And lezarva=1 And biz_header.biz_modul_kod=1301 And partner_id=partner.id),0) AS szlaosszbrutto
,coalesce((Select sum(ossz_brutto) From biz_header, biz_header_ext Where biz_header.kelte BETWEEN {1} AND {2} And biz_header_ext.biz_header_id=biz_header.id And lezarva=1 And biz_header.biz_modul_kod=1302 And partner_id=partner.id),0) AS szalosszbrutto
,coalesce((Select sum(ossz_brutto) From biz_header, biz_header_ext Where biz_header.kelte BETWEEN {1} AND {2} And biz_header_ext.biz_header_id=biz_header.id And lezarva=1 And biz_header.biz_modul_kod=1306 And partner_id=partner.id),0) AS arvosszbrutto
,coalesce((Select sum(ossz_brutto) From biz_header, biz_header_ext Where biz_header.kelte BETWEEN {1} AND {2} And biz_header_ext.biz_header_id=biz_header.id And lezarva=1 And biz_header.biz_modul_kod=1303 And partner_id=partner.id),0) AS nyugosszbrutto
,coalesce((Select sum(ossz_brutto) From biz_header, biz_header_ext Where biz_header.kelte BETWEEN {1} AND {2} And biz_header_ext.biz_header_id=biz_header.id And lezarva=1 And biz_header.biz_modul_kod=1301 And partner_id=partner.id),0) 
+ coalesce((Select sum(ossz_brutto) From biz_header, biz_header_ext Where biz_header.kelte BETWEEN {1} AND {2} And biz_header_ext.biz_header_id=biz_header.id And lezarva=1 And biz_header.biz_modul_kod=1306 And partner_id=partner.id),0) AS szlaosszbruttoarvetes
 FROM partner WHERE partner.kod<>0 
) t1 where not((szlaosszbrutto = 0) and (szalosszbrutto = 0) and (arvosszbrutto = 0) and (nyugosszbrutto = 0))
ORDER BY szalosszbrutto desc,kod 
